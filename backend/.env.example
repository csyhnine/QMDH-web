# =============================================================================
# QMDH-web Backend Local Development Environment Variables
# =============================================================================
# Copy to .env and adjust values as needed.
# For production deployment reference, see ../.env.production.example
# =============================================================================

# === database ===
QMDH_DATABASE_URL=sqlite:///./app.db

# === application ===
QMDH_FRONTEND_ORIGIN=http://localhost:5180
QMDH_TASK_EXECUTION_MODE=background
QMDH_MEDIA_ROOT=./storage/assets
QMDH_MEDIA_URL_PREFIX=/media

# === auth ===
# Legacy token-based auth (kept for backward compat during dev)
QMDH_AUTH_USERS_JSON=[{"name":"reviewer","token":"dev-reviewer-token","role":"reviewer","project_codes":["QMDH-001"]}]

# === providers ===
QMDH_OPENAI_IMAGE_API_KEY=
QMDH_OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
QMDH_OPENAI_IMAGE_MODEL=gpt-image-1
QMDH_OPENAI_IMAGE_TIMEOUT_SECONDS=90
QMDH_OPENAI_IMAGE_QUALITY=medium
QMDH_OPENAI_IMAGE_OUTPUT_FORMAT=png
QMDH_IMAGE_PROVIDER_PROFILES_JSON=[]

# === search (optional Meilisearch) ===
# Start with: docker compose up -d meilisearch
QMDH_MEILISEARCH_ENABLED=false
QMDH_MEILISEARCH_URL=http://127.0.0.1:7700
QMDH_MEILISEARCH_API_KEY=qmdh_meili_dev_key
QMDH_MEILISEARCH_INSPIRATION_INDEX=qmdh_inspiration
QMDH_MEILISEARCH_TEMPLATES_INDEX=qmdh_templates

# === studio agent (optional, default off) ===
QMDH_STUDIO_AGENT_ENABLED=false
