QMDH_DATABASE_URL=sqlite:///./app.db
QMDH_FRONTEND_ORIGIN=http://localhost:5180
QMDH_TASK_EXECUTION_MODE=background
QMDH_MEDIA_ROOT=./storage/assets
QMDH_MEDIA_URL_PREFIX=/media

# Real image provider: OpenAI Images API
QMDH_OPENAI_IMAGE_API_KEY=
QMDH_OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
QMDH_OPENAI_IMAGE_MODEL=gpt-image-1
QMDH_OPENAI_IMAGE_TIMEOUT_SECONDS=90
QMDH_OPENAI_IMAGE_QUALITY=medium
QMDH_OPENAI_IMAGE_OUTPUT_FORMAT=png

# Additional real image providers (OpenAI-compatible) can be mounted here as JSON.
# Example for ModelScope daily free quota.
# reference_mode=caption_prompt means: upload reference image -> caption it with a vision model -> enrich the text-to-image prompt.
# You can replace reference_caption_model with another ModelScope vision-language model if needed.
# QMDH_IMAGE_PROVIDER_PROFILES_JSON=[{"provider_name":"modelscope_free_image","api_key":"ms-xxx","base_url":"https://api-inference.modelscope.cn/v1","model_name":"MAILAND/majicflus_v1","adapter_kind":"openai_compatible","capabilities":["image.generate"],"quality":"high","output_format":"png","reference_mode":"caption_prompt","reference_caption_model":"Qwen/Qwen3-VL-8B-Instruct"}]
QMDH_IMAGE_PROVIDER_PROFILES_JSON=[]
