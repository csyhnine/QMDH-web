# =============================================================================
# QMDH-web Production Environment Variables
# =============================================================================
# All variables use the QMDH_ prefix and are read by pydantic-settings.
# Copy this file to .env and fill in the REQUIRED values before deployment.
# =============================================================================

# === database ===

# REQUIRED: PostgreSQL connection string for production database
# Format: postgresql+asyncpg://user:password@host:port/dbname
QMDH_DATABASE_URL=

# === redis ===

# REQUIRED: Redis connection URL for task queue, rate limiting, and session locks
# Format: redis://[:password@]host:port/db_number
QMDH_REDIS_URL=

# OPTIONAL (default: qmdh:tasks): Redis key prefix for the background task queue
QMDH_REDIS_QUEUE_NAME=qmdh:tasks

# === auth ===

# REQUIRED: Fernet-compatible key for encrypting sensitive data (API keys, tokens)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
QMDH_ENCRYPTION_KEY=

# OPTIONAL (default: 7): Number of days before an auth session expires
QMDH_AUTH_SESSION_DAYS=7

# OPTIONAL (default: [{"name":"reviewer",...}]): JSON array of token-based auth user profiles
# Each entry: {"name": "...", "token": "...", "role": "designer|reviewer|ops|admin", "project_codes": ["QMDH-001"]}
QMDH_AUTH_USERS_JSON=[{"name":"reviewer","token":"dev-reviewer-token","role":"reviewer","project_codes":["QMDH-001"]}]

# OPTIONAL (default: admin): Bootstrap admin username created on first startup
QMDH_BOOTSTRAP_ADMIN_NAME=admin

# OPTIONAL (default: dev-admin-password): Bootstrap admin password — CHANGE IN PRODUCTION
QMDH_BOOTSTRAP_ADMIN_PASSWORD=

# === storage ===

# OPTIONAL (default: local): Storage backend for uploaded and generated media files
# Allowed values: local, oss
QMDH_STORAGE_BACKEND=local

# OPTIONAL (default: ./storage/assets): Local filesystem path for media files (used when STORAGE_BACKEND=local)
QMDH_MEDIA_ROOT=./storage/assets

# OPTIONAL (default: /media): URL prefix for serving locally stored media files
QMDH_MEDIA_URL_PREFIX=/media

# OPTIONAL (default: empty): CDN base URL prepended to relative asset paths when serving files
# Format: https://cdn.example.com (no trailing slash)
QMDH_CDN_BASE_URL=

# === providers ===

# OPTIONAL (default: empty): OpenAI Images API key for the built-in image generation provider
QMDH_OPENAI_IMAGE_API_KEY=

# OPTIONAL (default: https://api.openai.com/v1): Base URL for OpenAI-compatible image API
QMDH_OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1

# OPTIONAL (default: gpt-image-1): Model name for OpenAI image generation
QMDH_OPENAI_IMAGE_MODEL=gpt-image-1

# OPTIONAL (default: 90): Timeout in seconds for image generation API calls
QMDH_OPENAI_IMAGE_TIMEOUT_SECONDS=90

# OPTIONAL (default: medium): Image quality setting (low, medium, high)
QMDH_OPENAI_IMAGE_QUALITY=medium

# OPTIONAL (default: png): Output format for generated images (png, jpg, svg)
QMDH_OPENAI_IMAGE_OUTPUT_FORMAT=png

# OPTIONAL (default: []): JSON array of additional OpenAI-compatible image provider profiles
# Each entry: {"provider_name":"...","api_key":"...","base_url":"...","model_name":"...","adapter_kind":"openai_compatible","capabilities":["image.generate"]}
QMDH_IMAGE_PROVIDER_PROFILES_JSON=[]

# === application ===

# OPTIONAL (default: http://localhost:5180): Single allowed frontend origin for CORS (fallback when CORS_ORIGINS is empty)
QMDH_FRONTEND_ORIGIN=http://localhost:5180

# OPTIONAL (default: empty): Comma-separated list of allowed CORS origins (overrides FRONTEND_ORIGIN when set)
# Format: https://app.example.com,https://staging.example.com (max 20 entries, max 253 chars each)
QMDH_CORS_ORIGINS=

# OPTIONAL (default: background): Task execution mode — determines how generation jobs are processed
# Allowed values: background, redis
QMDH_TASK_EXECUTION_MODE=background

# OPTIONAL (default: INFO): Minimum log level for backend output
# Allowed values: DEBUG, INFO, WARNING, ERROR, CRITICAL
QMDH_LOG_LEVEL=INFO

# OPTIONAL (default: json): Log output format
# Allowed values: json (structured JSON Lines for production), console (human-readable for local dev)
QMDH_LOG_FORMAT=json

# OPTIONAL (default: false): Enable API rate limiting (requires Redis)
# Allowed values: true, false (case-insensitive)
QMDH_RATE_LIMIT_ENABLED=false

# OPTIONAL (default: 60): Maximum general API requests per user per minute
QMDH_RATE_LIMIT_GENERAL_PER_MINUTE=60

# OPTIONAL (default: 10): Maximum AI generation requests per user per minute
QMDH_RATE_LIMIT_GENERATION_PER_MINUTE=10

# OPTIONAL (default: 10): Maximum login attempts per IP per minute
QMDH_RATE_LIMIT_LOGIN_PER_MINUTE=10

# OPTIONAL (default: 3600): Interval in seconds between session cleanup runs (range: 60-86400)
QMDH_SESSION_CLEANUP_INTERVAL_SECONDS=3600

# OPTIONAL (default: 500): Number of expired sessions to delete per batch (range: 50-5000)
QMDH_SESSION_CLEANUP_BATCH_SIZE=500
